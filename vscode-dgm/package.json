{
  "name": "dgm-devkit",
  "displayName": "DGM DevKit",
  "description": "Language tools for DGM (DangGiaMinh)",
  "version": "0.3.0",
  "publisher": "dgm-lang",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/DGM-lang-official/DGM-LANGUAGE-PROGRAMME-VISUAL-CODE-EXTENSIONS.git"
  },
  "bugs": {
    "url": "https://github.com/DGM-lang-official/DGM-LANGUAGE-PROGRAMME-VISUAL-CODE-EXTENSIONS/issues"
  },
  "homepage": "https://github.com/DGM-lang-official/DGM-LANGUAGE-PROGRAMME-VISUAL-CODE-EXTENSIONS#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Snippets"],
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:dgm",
    "onCommand:dgm.run",
    "onCommand:dgm.validate",
    "onCommand:dgm.version",
    "onCommand:dgm.restartLanguageServer"
  ],
  "contributes": {
    "languages": [
      {
        "id": "dgm",
        "aliases": ["DGM", "dgm"],
        "extensions": [".dgm"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "dgm",
        "scopeName": "source.dgm",
        "path": "./syntaxes/dgm.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "dgm",
        "path": "./snippets/dgm.json"
      }
    ],
    "commands": [
      {
        "command": "dgm.run",
        "title": "Run DGM File",
        "category": "DGM",
        "enablement": "resourceExtname == .dgm"
      },
      {
        "command": "dgm.version",
        "title": "Show DGM Version",
        "category": "DGM"
      },
      {
        "command": "dgm.validate",
        "title": "Validate DGM File",
        "category": "DGM",
        "enablement": "resourceExtname == .dgm"
      },
      {
        "command": "dgm.restartLanguageServer",
        "title": "Restart DGM Language Server",
        "category": "DGM"
      }
    ],
    "configuration": {
      "title": "DGM",
      "properties": {
        "dgm.binaryPath": {
          "type": "string",
          "default": "dgm",
          "description": "Path to the DGM executable used for run, validate, and LSP."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "dgm.run",
          "when": "resourceExtname == .dgm"
        },
        {
          "command": "dgm.validate",
          "when": "resourceExtname == .dgm"
        },
        {
          "command": "dgm.restartLanguageServer"
        }
      ]
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
