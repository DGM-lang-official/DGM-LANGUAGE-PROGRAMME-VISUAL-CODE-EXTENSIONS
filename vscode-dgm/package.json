{
  "name": "dgm-language",
  "displayName": "DGM Language Support",
  "description": "Syntax highlighting, hover, same-file navigation, snippets, and run/validate commands for DGM",
  "version": "0.2.0",
  "publisher": "dgm-lang",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/DGM-lang-official/DGM-LANGUAGE-PROGRAMME-VISUAL-CODE-EXTENSIONS.git"
  },
  "bugs": {
    "url": "https://github.com/DGM-lang-official/DGM-LANGUAGE-PROGRAMME-VISUAL-CODE-EXTENSIONS/issues"
  },
  "homepage": "https://github.com/DGM-lang-official/DGM-LANGUAGE-PROGRAMME-VISUAL-CODE-EXTENSIONS#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Snippets"],
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:dgm",
    "onCommand:dgm.run",
    "onCommand:dgm.validate",
    "onCommand:dgm.version"
  ],
  "contributes": {
    "languages": [
      {
        "id": "dgm",
        "aliases": ["DGM", "dgm"],
        "extensions": [".dgm"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "dgm",
        "scopeName": "source.dgm",
        "path": "./syntaxes/dgm.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "dgm",
        "path": "./snippets/dgm.json"
      }
    ],
    "commands": [
      {
        "command": "dgm.run",
        "title": "Run DGM File",
        "category": "DGM",
        "enablement": "resourceExtname == .dgm"
      },
      {
        "command": "dgm.version",
        "title": "Show DGM Version",
        "category": "DGM"
      },
      {
        "command": "dgm.validate",
        "title": "Validate DGM File",
        "category": "DGM",
        "enablement": "resourceExtname == .dgm"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "dgm.run",
          "when": "resourceExtname == .dgm"
        },
        {
          "command": "dgm.validate",
          "when": "resourceExtname == .dgm"
        }
      ]
    }
  }
}
