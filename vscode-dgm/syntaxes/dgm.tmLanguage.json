<?xml version="1.0" encoding="UTF-8"?>
<plist version="1.0">
<dict>
  <key>name</key>
  <string>DGM</string>
  <key>scopeName</key>
  <string>source.dgm</string>
  <key>fileTypes</key>
  <array>
    <string>dgm</string>
  </array>
  <key>patterns</key>
  <array>
    <dict>
      <key>include</key>
      <string>#comments</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#strings</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#fstrings</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#numbers</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#keywords</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#booleans</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#null</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#operators</string>
    </dict>
    <dict>
      <key>include</key>
      <string>#functions</string>
    </dict>
  </array>
  <key>repository</key>
  <dict>
    <key>comments</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key>
          <string>comment.line.dgm</string>
          <key>match</key>
          <string>#.*?$</string>
        </dict>
      </array>
    </dict>
    <key>strings</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key>
          <string>string.quoted.double.dgm</string>
          <key>begin</key>
          <string>"</string>
          <key>end</key>
          <string>"</string>
          <key>beginCaptures</key>
          <dict>
            <key>0</key>
            <dict>
              <key>name</key>
              <string>punctuation.definition.string.begin.dgm</string>
            </dict>
          </dict>
          <key>endCaptures</key>
          <dict>
            <key>0</key>
            <dict>
              <key>name</key>
              <string>punctuation.definition.string.end.dgm</string>
            </dict>
          </dict>
          <key>patterns</key>
          <array>
            <dict>
              <key>name</key>
              <string>constant.character.escape.dgm</string>
              <key>match</key>
              <string>\\([\\"]|[ntr])</string>
            </dict>
          </array>
        </dict>
      </array>
    </dict>
    <key>fstrings</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key>
          <string>string.interpolated.dgm</string>
          <key>begin</key>
          <string>f"</string>
          <key>end</key>
          <string>"</string>
          <key>patterns</key>
          <array>
            <dict>
              <key>name</key>
              <string>constant.character.escape.dgm</string>
              <key>match</key>
              <string>\\([\\"]|[ntr])</string>
            </dict>
            <dict>
              <key>name</key>
              <string>meta.embedded.expression.dgm</string>
              <key>begin</key>
              <string>\{</string>
              <key>end</key>
              <string>\}</string>
              <key>patterns</key>
              <array>
                <dict>
                  <key>include</key>
                  <string>source.dgm</string>
                </dict>
              </array>
            </dict>
          </array>
        </dict>
      </array>
    </dict>
    <key>numbers</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key>
          <string>constant.numeric.float.dgm</string>
          <key>match</key>
          <string>\b[0-9]+\.[0-9]+\b</string>
        </dict>
        <dict>
          <key>name</key>
          <string>constant.numeric.integer.dgm</string>
          <key>match</key>
          <string>\b[0-9]+\b</string>
        </dict>
      </array>
    </dict>
    <key>keywords</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key>
          <string>keyword.control.dgm</string>
          <key>match</key>
          <string>\b(iff|els|elseif|whl|fr|brk|cont|retrun|try|catch|finally|throw|match)\b</string>
        </dict>
        <dict>
          <key>name</key>
          <string>keyword.declaration.dgm</string>
          <key>match</key>
          <string>\b(let|def|cls|new|extends|imprt)\b</string>
        </dict>
        <dict>
          <key>name</key>
          <string>keyword.operator.dgm</string>
          <key>match</key>
          <string>\b(and|or|not|in)\b</string>
        </dict>
        <dict>
          <key>name</key>
          <string>keyword.other.dgm</string>
          <key>match</key>
          <string>\b(writ|ths|lam)\b</string>
        </dict>
      </array>
    </dict>
    <key>booleans</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key>
          <string>constant.language.boolean.dgm</string>
          <key>match</key>
          <string>\b(tru|fals)\b</string>
        </dict>
      </array>
    </dict>
    <key>null</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key>
          <string>constant.language.null.dgm</string>
          <key>match</key>
          <string>\bnul\b</string>
        </dict>
      </array>
    </dict>
    <key>operators</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key>
          <string>keyword.operator.assignment.dgm</string>
          <key>match</key>
          <string>(\+=|-=|\*=|/=|%=|=)(?!=)</string>
        </dict>
        <dict>
          <key>name</key>
          <string>keyword.operator.comparison.dgm</string>
          <key>match</key>
          <string>(==|!=|&lt;=|&gt;=|&lt;|&gt;)</string>
        </dict>
        <dict>
          <key>name</key>
          <string>keyword.operator.arithmetic.dgm</string>
          <key>match</key>
          <string>(\+|-|\*|/|%|&lt;&lt;|&gt;&gt;|\*\*)</string>
        </dict>
        <dict>
          <key>name</key>
          <string>keyword.operator.bitwise.dgm</string>
          <key>match</key>
          <string>(&amp;|\||\^|~|!)</string>
        </dict>
        <dict>
          <key>name</key>
          <string>keyword.operator.other.dgm</string>
          <key>match</key>
          <string>(\.\.|\?|=>)</string>
        </dict>
      </array>
    </dict>
    <key>functions</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key>
          <string>entity.name.function.dgm</string>
          <key>match</key>
          <string>\b([a-zA-Z_][a-zA-Z0-9_]*)\s*(?=\()</string>
        </dict>
      </array>
    </dict>
  </dict>
</dict>
</plist>
