{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "DGM",
  "scopeName": "source.dgm",
  "fileTypes": [
    "dgm"
  ],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#fstrings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#booleans" },
    { "include": "#null" },
    { "include": "#operators" },
    { "include": "#functions" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.dgm",
          "match": "#.*?$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.dgm",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.dgm"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.dgm"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.dgm",
              "match": "\\\\([\\\\\"]\"|[ntr])"
            }
          ]
        }
      ]
    },
    "fstrings": {
      "patterns": [
        {
          "name": "string.interpolated.dgm",
          "begin": "f\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.dgm",
              "match": "\\\\([\\\\\"]\"|[ntr])"
            },
            {
              "name": "meta.embedded.expression.dgm",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [
                {
                  "include": "source.dgm"
                }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.dgm",
          "match": "\\b0[xX][0-9A-Fa-f]+\\b"
        },
        {
          "name": "constant.numeric.binary.dgm",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.octal.dgm",
          "match": "\\b0[oO][0-7]+\\b"
        },
        {
          "name": "constant.numeric.float.dgm",
          "match": "\\b(?:[0-9][0-9_]*\\.[0-9][0-9_]*(?:[eE][+-]?[0-9]+)?|[0-9][0-9_]*[eE][+-]?[0-9]+)\\b"
        },
        {
          "name": "constant.numeric.integer.dgm",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.dgm",
          "match": "\\b(iff|els|elseif|whl|fr|brk|cont|retrun|try|catch|finally|throw|match)\\b"
        },
        {
          "name": "keyword.declaration.dgm",
          "match": "\\b(let|def|cls|new|extends|imprt)\\b"
        },
        {
          "name": "keyword.operator.dgm",
          "match": "\\b(and|or|not|in)\\b"
        },
        {
          "name": "keyword.other.dgm",
          "match": "\\b(writ|ths|lam)\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.dgm",
          "match": "\\b(tru|fals|true|false)\\b"
        }
      ]
    },
    "null": {
      "patterns": [
        {
          "name": "constant.language.null.dgm",
          "match": "\\b(nul|null)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.dgm",
          "match": "(\\+=|-=|\\*=|/=|%=|=)(?!=)"
        },
        {
          "name": "keyword.operator.comparison.dgm",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.dgm",
          "match": "(\\+|-|\\*|/|%|<<|>>|\\*\\*)"
        },
        {
          "name": "keyword.operator.bitwise.dgm",
          "match": "(&|\\||\\^|~|!)"
        },
        {
          "name": "keyword.operator.other.dgm",
          "match": "(\\.\\.|\\?|=>)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.dgm",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    }
  }
}
